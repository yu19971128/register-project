@echo off
goto __new_entry

REM Main execution entry point. Embedded bundles are appended below.
:__new_entry
setlocal EnableExtensions
cd /d "%~dp0"
chcp 65001 >nul

set "PROJECT_DIR=%cd%"
set "DOCS_DIR=%PROJECT_DIR%\docs"
set "INIT_PROJECT_BAT=%~f0"
set "CONTENT_BUNDLE_ZIP=%TEMP%\gstack-init-content.zip"
set "CONTENT_EXTRACT_DIR=%TEMP%\gstack-init-content-%RANDOM%%RANDOM%"
set "SCRIPT_BUNDLE_ZIP=%TEMP%\gstack-init-scripts.zip"
set "SCRIPT_EXTRACT_DIR=%TEMP%\gstack-init-scripts-%RANDOM%%RANDOM%"

echo [INFO] Initializing GSD Stack scaffold...
echo [INFO] Target directory: %PROJECT_DIR%

if not exist "%DOCS_DIR%" mkdir "%DOCS_DIR%"
if not exist "%PROJECT_DIR%\docs" mkdir "%PROJECT_DIR%\docs"
if not exist "%DOCS_DIR%\01-background" mkdir "%DOCS_DIR%\01-background"
if not exist "%DOCS_DIR%\02-modules" mkdir "%DOCS_DIR%\02-modules"
if not exist "%DOCS_DIR%\02-modules\orchestrator" mkdir "%DOCS_DIR%\02-modules\orchestrator"
if not exist "%DOCS_DIR%\02-modules\_template" mkdir "%DOCS_DIR%\02-modules\_template"
if not exist "%DOCS_DIR%\03-architecture" mkdir "%DOCS_DIR%\03-architecture"
if not exist "%DOCS_DIR%\03-architecture\data-flows" mkdir "%DOCS_DIR%\03-architecture\data-flows"
if not exist "%DOCS_DIR%\04-frontend" mkdir "%DOCS_DIR%\04-frontend"
if not exist "%DOCS_DIR%\04-frontend\_template" mkdir "%DOCS_DIR%\04-frontend\_template"
if not exist "%DOCS_DIR%\04-frontend\features" mkdir "%DOCS_DIR%\04-frontend\features"
if not exist "%DOCS_DIR%\05-database" mkdir "%DOCS_DIR%\05-database"
if not exist "%DOCS_DIR%\05-database\schemas" mkdir "%DOCS_DIR%\05-database\schemas"
if not exist "%DOCS_DIR%\06-api" mkdir "%DOCS_DIR%\06-api"
if not exist "%DOCS_DIR%\06-api\_template" mkdir "%DOCS_DIR%\06-api\_template"
if not exist "%DOCS_DIR%\07-tasks" mkdir "%DOCS_DIR%\07-tasks"
if not exist "%DOCS_DIR%\07-tasks\_templates" mkdir "%DOCS_DIR%\07-tasks\_templates"
if not exist "%PROJECT_DIR%\scripts" mkdir "%PROJECT_DIR%\scripts"
if not exist "%PROJECT_DIR%\workflow" mkdir "%PROJECT_DIR%\workflow"

powershell -NoLogo -NoProfile -Command "$ErrorActionPreference='Stop'; $scriptPath=$env:INIT_PROJECT_BAT; $zipPath=$env:CONTENT_BUNDLE_ZIP; $extractPath=$env:CONTENT_EXTRACT_DIR; $startMarker='__CONTENT_BUNDLE_B64_BEGIN__'; $endMarker='__CONTENT_BUNDLE_B64_END__'; $lines=Get-Content -LiteralPath $scriptPath -Encoding UTF8; $collect=$false; $chunks=New-Object System.Collections.Generic.List[string]; foreach($line in $lines){ if($line -eq ('REM ' + $startMarker)){ $collect=$true; continue }; if($line -eq ('REM ' + $endMarker)){ break }; if($collect -and $line.StartsWith('REM ')){ $chunks.Add($line.Substring(4)) } }; [System.IO.File]::WriteAllBytes($zipPath,[System.Convert]::FromBase64String(($chunks -join ''))); if(Test-Path -LiteralPath $extractPath){ Remove-Item -LiteralPath $extractPath -Recurse -Force }; Expand-Archive -LiteralPath $zipPath -DestinationPath $extractPath -Force" >nul
if errorlevel 1 exit /b %errorlevel%

robocopy "%CONTENT_EXTRACT_DIR%" "%PROJECT_DIR%" /E /NFL /NDL /NJH /NJS /NC /NS /NP /R:0 /W:0 >nul
if errorlevel 8 exit /b %errorlevel%

if exist "%PROJECT_DIR%\AGENTS.md" copy /Y "%PROJECT_DIR%\AGENTS.md" "%PROJECT_DIR%\CLAUDE.md" >nul

powershell -NoLogo -NoProfile -Command "$ErrorActionPreference='Stop'; $scriptPath=$env:INIT_PROJECT_BAT; $zipPath=$env:SCRIPT_BUNDLE_ZIP; $extractPath=$env:SCRIPT_EXTRACT_DIR; $startMarker='__SCRIPT_BUNDLE_B64_BEGIN__'; $endMarker='__SCRIPT_BUNDLE_B64_END__'; $lines=Get-Content -LiteralPath $scriptPath -Encoding UTF8; $collect=$false; $chunks=New-Object System.Collections.Generic.List[string]; foreach($line in $lines){ if($line -eq ('REM ' + $startMarker)){ $collect=$true; continue }; if($line -eq ('REM ' + $endMarker)){ break }; if($collect -and $line.StartsWith('REM ')){ $chunks.Add($line.Substring(4)) } }; [System.IO.File]::WriteAllBytes($zipPath,[System.Convert]::FromBase64String(($chunks -join ''))); if(Test-Path -LiteralPath $extractPath){ Remove-Item -LiteralPath $extractPath -Recurse -Force }; Expand-Archive -LiteralPath $zipPath -DestinationPath $extractPath -Force" >nul
if errorlevel 1 exit /b %errorlevel%

robocopy "%SCRIPT_EXTRACT_DIR%" "%PROJECT_DIR%\scripts" *.bat /NFL /NDL /NJH /NJS /NC /NS /NP /R:0 /W:0 >nul
if errorlevel 8 exit /b %errorlevel%

if exist "%~dp0scripts\*.bat" copy /Y "%~dp0scripts\*.bat" "%PROJECT_DIR%\scripts\" >nul
if exist "%PROJECT_DIR%\scripts\*.sh" del /q "%PROJECT_DIR%\scripts\*.sh" >nul 2>nul
powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -Command "$ErrorActionPreference='Stop'; $scriptDir=Join-Path $env:PROJECT_DIR 'scripts'; if(-not (Test-Path -LiteralPath $scriptDir)){ exit 0 }; $utf8NoBom=[System.Text.UTF8Encoding]::new($false); $template=[Text.Encoding]::UTF8.GetString([Convert]::FromBase64String('')); $wrapperFiles=Get-ChildItem -LiteralPath $scriptDir -File -Filter '*.bat' | Where-Object { $_.Name -ne 'gsd-script-core.bat' }; foreach($file in $wrapperFiles){ $command=[System.IO.Path]::GetFileNameWithoutExtension($file.Name); $content=$template.Replace('__COMMAND__',$command); [System.IO.File]::WriteAllText($file.FullName, $content, $utf8NoBom) }" >nul
if errorlevel 1 exit /b %errorlevel%

if exist "%CONTENT_EXTRACT_DIR%" rmdir /s /q "%CONTENT_EXTRACT_DIR%"
if exist "%CONTENT_BUNDLE_ZIP%" del /q "%CONTENT_BUNDLE_ZIP%" >nul 2>nul
if exist "%SCRIPT_EXTRACT_DIR%" rmdir /s /q "%SCRIPT_EXTRACT_DIR%"
if exist "%SCRIPT_BUNDLE_ZIP%" del /q "%SCRIPT_BUNDLE_ZIP%" >nul 2>nul

if not exist ".git" (
    echo [INFO] Initializing git repository...
    git init >nul 2>&1
)

if exist "%PROJECT_DIR%\scripts\doc-lint.bat" (
    call "%PROJECT_DIR%\scripts\doc-lint.bat" >nul 2>&1
    if errorlevel 1 exit /b %errorlevel%
)

if exist "%PROJECT_DIR%\scripts\doc-sync-v2.bat" (
    call "%PROJECT_DIR%\scripts\doc-sync-v2.bat" --validate >nul 2>&1
    if errorlevel 1 exit /b %errorlevel%
)

echo [OK] Project scaffold initialized.
endlocal
exit /b 0
